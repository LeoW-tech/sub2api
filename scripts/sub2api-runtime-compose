#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="${SUB2API_REPO_ROOT:-$(cd -- "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
BASE_COMPOSE_FILE="$REPO_ROOT/deploy/local/docker-compose.runtime.yml"
LINUX_OVERRIDE_FILE="$REPO_ROOT/deploy/local/docker-compose.runtime.linux.yml"

default_runtime_root() {
  local repo_runtime="$REPO_ROOT/runtime"
  local sibling_runtime

  sibling_runtime="$(cd -- "$REPO_ROOT/.." && pwd)/runtime"

  if [[ -e "$repo_runtime/stable/.env" || -d "$repo_runtime" ]]; then
    printf '%s\n' "$repo_runtime"
    return 0
  fi

  if [[ -e "$sibling_runtime/stable/.env" || -d "$sibling_runtime" ]]; then
    printf '%s\n' "$sibling_runtime"
    return 0
  fi

  printf '%s\n' "$repo_runtime"
}

RUNTIME_ROOT="${SUB2API_RUNTIME_ROOT:-$(default_runtime_root)}"

maybe_reexec_with_sudo() {
  local stable_env="$RUNTIME_ROOT/stable/.env"
  local -a sudo_env_args=(
    "SUB2API_REPO_ROOT=$REPO_ROOT"
    "SUB2API_RUNTIME_ROOT=$RUNTIME_ROOT"
  )

  if [[ "$(uname -s)" != "Linux" || "$(id -u)" -eq 0 ]]; then
    return 0
  fi

  if [[ -n "${NPM_REGISTRY:-}" ]]; then
    sudo_env_args+=("NPM_REGISTRY=$NPM_REGISTRY")
  fi

  if [[ -e "$stable_env" && ! -r "$stable_env" ]]; then
    if command -v sudo >/dev/null 2>&1 && sudo -n test -r "$stable_env" >/dev/null 2>&1; then
      exec sudo -n env "${sudo_env_args[@]}" "$0" "$@"
    fi
  fi
}

usage() {
  cat <<'EOF'
用法:
  ./scripts/sub2api-runtime-compose <stable|dev> [docker compose args...]
  ./scripts/sub2api-runtime-compose <stable|dev> --print-compose-files
EOF
}

die() {
  echo "错误: $*" >&2
  exit 1
}

compose_files() {
  local -a files=("$BASE_COMPOSE_FILE")

  [[ -f "$BASE_COMPOSE_FILE" ]] || die "缺少 compose 文件: $BASE_COMPOSE_FILE"

  if [[ "$(uname -s)" == "Linux" ]]; then
    [[ -f "$LINUX_OVERRIDE_FILE" ]] || die "缺少 Linux compose override: $LINUX_OVERRIDE_FILE"
    files+=("$LINUX_OVERRIDE_FILE")
  fi

  printf '%s\n' "${files[@]}"
}

main() {
  maybe_reexec_with_sudo "$@"

  [[ $# -ge 2 ]] || { usage; exit 1; }

  local env_name="$1"
  shift

  local env_dir="$RUNTIME_ROOT/$env_name"
  local env_file="$env_dir/.env"
  local -a compose_args=()

  [[ "$env_name" == "stable" || "$env_name" == "dev" ]] || die "环境仅支持 stable 或 dev。"
  [[ -f "$env_file" ]] || die "缺少环境文件: $env_file"

  export RUNTIME_DATA_DIR="$env_dir/data"
  export RUNTIME_POSTGRES_DIR="$env_dir/postgres_data"
  export RUNTIME_REDIS_DIR="$env_dir/redis_data"
  export COMPOSE_PROJECT_NAME="sub2api_${env_name}"

  mkdir -p "$RUNTIME_DATA_DIR" "$RUNTIME_POSTGRES_DIR" "$RUNTIME_REDIS_DIR"

  if [[ "${1:-}" == "--print-compose-files" ]]; then
    compose_files
    exit 0
  fi

  while IFS= read -r compose_file; do
    compose_args+=(-f "$compose_file")
  done < <(compose_files)

  exec docker compose \
    --project-name "$COMPOSE_PROJECT_NAME" \
    --env-file "$env_file" \
    "${compose_args[@]}" \
    "$@"
}

main "$@"
